{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "functions": {
    "server.js": {
      "maxDuration": 30
    }
  },
  "routes": [
    { "src": "/manifest.json", "dest": "/public/manifest.json" },
    { "src": "/sw.js",         "dest": "/public/sw.js" },
    { "src": "/(.*)",          "dest": "server.js" }
  ]
}
